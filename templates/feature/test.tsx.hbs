import { expect } from "vitest";
import { screen, waitFor } from "@testing-library/react";
import { test } from "@cvx/test.setup";
import { renderWithRouter } from "@/test-helpers";
import { {{pascalCase name}}Page } from "./index";

test("renders {{pascalCase name}} page", async ({ client }) => {
  renderWithRouter(<{{pascalCase name}}Page />, client);

  await waitFor(() => {
    expect(screen.getByText("{{pascalCase name}}")).toBeInTheDocument();
  });
});
