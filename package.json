{
  "name": "feather-starter-convex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite",
    "dev:backend": "convex dev",
    "predev": "convex dev --run init --until-success",
    "build": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && vite build",
    "lint": "eslint . --ignore-pattern convex/_generated --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p convex/tsconfig.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/react-query": "^0.1.0",
    "@epic-web/client-hints": "^1.3.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@react-email/components": "0.0.22",
    "@react-email/render": "^2.0.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.3",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "@xixixao/uploadstuff": "^0.0.5",
    "class-variance-authority": "^0.7.0",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.114",
    "cookie": "^0.6.0",
    "i18next": "^23.12.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^2.5.2",
    "lucide-react": "^0.416.0",
    "npm-run-all": "^4.1.5",
    "oslo": "^1.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^15.0.0",
    "resend": "^3.2.0",
    "stripe": "^16.6.0",
    "tailwind-merge": "^2.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@tanstack/router-devtools": "^1.166.3",
    "@tanstack/router-plugin": "^1.166.3",
    "@types/cookie": "^0.6.0",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^20.14.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "prettier": "3.3.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^7.17.0",
    "vite": "^7.3.1"
  }
}
